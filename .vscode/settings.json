{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  // "oxc.fmt.configPath": ".config/oxfmt.config.ts",
  // "oxc.configPath": ".config/oxlint.config.ts",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.organizeImports": "always" // let oxfmt handle import organization
  }
}
